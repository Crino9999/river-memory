# River Memory System 配置
# 复制此文件为 .env 后修改

# LLM API 配置 (OpenAI 兼容接口)
API_BASE=https://opencode.ai/zen/go/v1
API_KEY=your-api-key-here
MODEL=deepseek-v4-flash

# Embedding 模型
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 存储路径
CHROMA_DIR=./chroma_data
DB_PATH=./river.db

# 检索配置
TOP_K=5

# 探针权重
PROBE_WEIGHT_SEMANTIC=1
PROBE_WEIGHT_TIME=2
PROBE_WEIGHT_OBJECT=3
PROBE_WEIGHT_ENV=1

# LLM 调用配置
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_TIMEOUT=60

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./river.log

# 会话配置
SESSION_MAX_HISTORY=20
SESSION_AUTO_INGEST=true

# 去重配置
DEDUP_WINDOW_DAYS=1

# 是否使用真实 embedding (sentence-transformers，需联网下载模型)
# 设置为 false 则使用离线 TF-IDF 回退
USE_REAL_EMBED=false
